{
  "permissions": {
    "allow": [
      "Bash"
    ],
    "deny": [],
    "defaultMode": "auto"
  },
  "enabledPlugins": {
    "dynamo-ai-workflows@dynamo-ai-workflows": true
  },
  "extraKnownMarketplaces": {
    "dynamo-ai-workflows": {
      "source": {
        "source": "directory",
        "path": "/home/connorc/workflows"
      }
    }
  },
  "sandbox": {
    "enabled": false,
    "failIfUnavailable": false,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowAllUnixSockets": true
    },
    "filesystem": {
      "allowWrite": [
        "."
      ]
    },
    "mode": "auto-allow"
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "editorMode": "vim",
  "verbose": true,
  "skipAutoPermissionPrompt": true
}

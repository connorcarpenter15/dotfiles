{
  "permissions": {
    "allow": [],
    "deny": [],
    "defaultMode": "bypassPermissions"
  },
  "model": "claude-opus-4-8",
  "enabledPlugins": {
    "dynamo-ai-workflows@dynamo-ai-workflows": true
  },
  "extraKnownMarketplaces": {
    "dynamo-ai-workflows": {
      "source": {
        "source": "directory",
        "path": "/home/connorc/workflows"
      }
    }
  },
  "sandbox": {
    "enabled": false,
    "failIfUnavailable": false,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowAllUnixSockets": true
    },
    "filesystem": {
      "allowWrite": [
        "."
      ]
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "theme": "dark",
  "editorMode": "vim",
  "verbose": true,
  "skipAutoPermissionPrompt": true,
  "effortLevel": "xhigh"
}

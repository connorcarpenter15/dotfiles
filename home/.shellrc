# Shared interactive shell settings for zsh and Bash.

_shellrc_prepend_path() {
  [ -n "$1" ] || return

  case ":$PATH:" in
    *":$1:"*) ;;
    *) PATH="$1:$PATH" ;;
  esac
}

_shellrc_prepend_path_if_dir() {
  [ -d "$1" ] && _shellrc_prepend_path "$1"
}

_shellrc_source_if_readable() {
  [ -r "$1" ] && . "$1"
}

_shellrc_setup_nix() {
  if [ -r /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh ]; then
    . /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh
  elif [ -r "$HOME/.nix-profile/etc/profile.d/nix.sh" ]; then
    . "$HOME/.nix-profile/etc/profile.d/nix.sh"
  fi
}

_shellrc_setup_homebrew() {
  if command -v brew >/dev/null 2>&1; then
    eval "$(brew shellenv)"
    return
  fi

  for brew in \
    /opt/homebrew/bin/brew \
    /usr/local/bin/brew \
    /home/linuxbrew/.linuxbrew/bin/brew \
    "$HOME/.linuxbrew/bin/brew"
  do
    if [ -x "$brew" ]; then
      eval "$("$brew" shellenv)"
      return
    fi
  done
}

_shellrc_setup_home_manager() {
  _shellrc_source_if_readable "$HOME/.nix-profile/etc/profile.d/hm-session-vars.sh"

  if [ -n "${USER:-}" ]; then
    _shellrc_source_if_readable "/etc/profiles/per-user/$USER/etc/profile.d/hm-session-vars.sh"
  fi
}

# Environment
_shellrc_setup_nix
_shellrc_setup_homebrew
_shellrc_setup_home_manager

export EDITOR="${EDITOR:-nvim}"
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"

case "$(uname -s 2>/dev/null)" in
  Darwin) export PNPM_HOME="${PNPM_HOME:-$HOME/Library/pnpm}" ;;
  *) export PNPM_HOME="${PNPM_HOME:-$HOME/.local/share/pnpm}" ;;
esac

_shellrc_prepend_path "$PNPM_HOME"
_shellrc_prepend_path_if_dir "$HOME/.antigravity/antigravity/bin"
export PATH

[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && . "$NVM_DIR/bash_completion"

# Aliases
alias q='exit'
alias g='git'
alias e='yazi'
alias l='ls -al'
alias la='ls -a'
alias home='cd ~'
alias n='nvim'
alias v='nvim'
alias n.='nvim .'
alias pv='uv run nvim'
alias ns='nvim -c "lua require('\''persistence'\'').load()"'
alias lg='lazygit'
alias gs='git status -s'
alias gl="git log --all --graph --pretty=format:'%C(magenta)%h %C(white) %an %ar%C(auto) %D%n%s%n'"
alias cp='cp -i'
alias mv='mv -i'
alias rm='trash -v'
alias ping='ping -c 10'
alias psa='btop -p 1'
alias su='su - '
alias pwsh='pwsh.exe'
alias config='cd "$HOME/.config/nvim" && nvim'
alias g++='g++ -std=c++20'
alias mcserver='ssh -i "$HOME/.ssh/mudgies_server.key" ubuntu@141.148.62.216'

if command -v eza >/dev/null 2>&1; then
  alias ls='eza --color=always --icons=always --group-directories-first'
fi

[ -r "$HOME/.shellrc.local" ] && . "$HOME/.shellrc.local"

unset -f _shellrc_prepend_path _shellrc_prepend_path_if_dir _shellrc_source_if_readable _shellrc_setup_nix _shellrc_setup_homebrew _shellrc_setup_home_manager 2>/dev/null || true

background = #0D0D0D
adjust-cell-height = 6
adjust-cell-width = -1
macos-option-as-alt = left

# Set the cursor style to block
cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor

# Remove the title bar and borders
window-decoration = none

# Change this for transparent background
background-opacity = 1
keybind = "ctrl+backspace=text:\x17"
keybind = "cmd+shift+m=toggle_fullscreen"
keybind = "cmd+enter=unbind"
keybind = "cmd+[=unbind"
keybind = "cmd+]=unbind"
keybind = "ctrl+shift+h=previous_tab"
keybind = "ctrl+shift+l=next_tab"

palette = 0=#0D0D0D
palette = 1=#C4746E
palette = 2=#8A9A7B
palette = 3=#C8AE81
palette = 4=#8BA4B0
palette = 5=#A292A3
palette = 6=#95AEAC
palette = 7=#C5C9C5
palette = 8=#393836
palette = 9=#E46876
palette = 10=#87A987
palette = 11=#DCA561
palette = 12=#7FB4CA
palette = 13=#938AA9
palette = 14=#7AA89F
palette = 15=#FFFFFF

foreground = #C5C9C5
cursor-color = #C5C9C9
cursor-text = #0D0D0D
selection-background = #393836
selection-foreground = #C5C9C5

# Ensure Ghostty quits when the last window is closed
quit-after-last-window-closed = true

# Hide the mouse cursor when typing
mouse-hide-while-typing = true

# Automatically install terminfo on remote host
# shell-integration-features = ssh-terminfo
